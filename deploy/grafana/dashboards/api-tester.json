{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Calls Total",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (result) (increase(api_tester_calls_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Call Duration P95 (ms)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_tester_call_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Discovered Endpoints",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "api_tester_discovered_endpoints"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Last Run Success %",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "api_tester_last_run_success_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Workers",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "api_tester_active_workers"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Runs Finished",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(api_tester_runs_total{status=\"finished\"}[1h])",
          "legendFormat": "{{mode}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "api-tester"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "API Tester",
  "version": 1
}